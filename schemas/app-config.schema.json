{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://zeroeye.dev/schemas/app-config.json",
  "title": "Tent of Trials Application Configuration",
  "description": "Configuration structure for the Tent of Trials platform, generated by tools/config_generator.py. Supports multiple environments (development, staging, production) with environment-specific overrides.",
  "type": "object",
  "required": ["app", "server", "database", "redis", "kafka", "market", "auth", "monitoring", "features"],
  "properties": {
    "app": {
      "type": "object",
      "description": "Core application metadata and behavior settings",
      "required": ["name", "version", "environment", "debug", "log_level", "log_format"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Application name identifier",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "version": {
          "type": "string",
          "description": "Semantic version string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "environment": {
          "type": "string",
          "description": "Deployment environment",
          "enum": ["development", "staging", "production"]
        },
        "debug": {
          "type": "boolean",
          "description": "Enable debug mode (should be false in production)"
        },
        "log_level": {
          "type": "string",
          "description": "Logging verbosity level",
          "enum": ["debug", "info", "warn", "error"]
        },
        "log_format": {
          "type": "string",
          "description": "Log output format",
          "enum": ["json", "text"]
        }
      },
      "additionalProperties": false
    },
    "server": {
      "type": "object",
      "description": "HTTP server configuration",
      "required": ["host", "port", "read_timeout", "write_timeout", "idle_timeout", "max_header_bytes", "shutdown_timeout"],
      "properties": {
        "host": {
          "type": "string",
          "description": "Bind address for the HTTP server"
        },
        "port": {
          "type": "integer",
          "description": "Port number for the HTTP server",
          "minimum": 1,
          "maximum": 65535
        },
        "read_timeout": {
          "type": "integer",
          "description": "Read timeout in seconds",
          "minimum": 1
        },
        "write_timeout": {
          "type": "integer",
          "description": "Write timeout in seconds",
          "minimum": 1
        },
        "idle_timeout": {
          "type": "integer",
          "description": "Idle connection timeout in seconds",
          "minimum": 1
        },
        "max_header_bytes": {
          "type": "integer",
          "description": "Maximum HTTP header size in bytes",
          "minimum": 1024
        },
        "shutdown_timeout": {
          "type": "integer",
          "description": "Graceful shutdown timeout in seconds",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "database": {
      "type": "object",
      "description": "PostgreSQL database connection and pool configuration",
      "required": ["host", "port", "name", "user", "password", "pool_min", "pool_max", "timeout_ms", "ssl_mode"],
      "properties": {
        "host": {
          "type": "string",
          "description": "Database server hostname"
        },
        "port": {
          "type": "integer",
          "description": "Database server port",
          "minimum": 1,
          "maximum": 65535
        },
        "name": {
          "type": "string",
          "description": "Database name"
        },
        "user": {
          "type": "string",
          "description": "Database username"
        },
        "password": {
          "type": "string",
          "description": "Database password (should be set via environment variable or vault in production)"
        },
        "pool_min": {
          "type": "integer",
          "description": "Minimum connection pool size",
          "minimum": 0
        },
        "pool_max": {
          "type": "integer",
          "description": "Maximum connection pool size",
          "minimum": 1
        },
        "timeout_ms": {
          "type": "integer",
          "description": "Connection timeout in milliseconds",
          "minimum": 100
        },
        "ssl_mode": {
          "type": "string",
          "description": "PostgreSQL SSL mode",
          "enum": ["disable", "allow", "prefer", "require", "verify-ca", "verify-full"]
        }
      },
      "additionalProperties": false
    },
    "redis": {
      "type": "object",
      "description": "Redis cache and session store configuration",
      "required": ["host", "port", "password", "db", "pool_size", "timeout_ms"],
      "properties": {
        "host": {
          "type": "string",
          "description": "Redis server hostname"
        },
        "port": {
          "type": "integer",
          "description": "Redis server port",
          "minimum": 1,
          "maximum": 65535
        },
        "password": {
          "type": "string",
          "description": "Redis authentication password"
        },
        "db": {
          "type": "integer",
          "description": "Redis database index",
          "minimum": 0,
          "maximum": 15
        },
        "pool_size": {
          "type": "integer",
          "description": "Connection pool size",
          "minimum": 1
        },
        "timeout_ms": {
          "type": "integer",
          "description": "Connection timeout in milliseconds",
          "minimum": 100
        }
      },
      "additionalProperties": false
    },
    "kafka": {
      "type": "object",
      "description": "Apache Kafka message broker configuration",
      "required": ["brokers", "group_id", "client_id", "timeout_ms", "retry_count", "retry_backoff_ms", "enable_auto_commit", "auto_commit_interval_ms"],
      "properties": {
        "brokers": {
          "type": "array",
          "description": "List of Kafka broker addresses",
          "items": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9.-]+:[0-9]+$"
          },
          "minItems": 1
        },
        "group_id": {
          "type": "string",
          "description": "Consumer group identifier"
        },
        "client_id": {
          "type": "string",
          "description": "Client identifier for Kafka connections"
        },
        "timeout_ms": {
          "type": "integer",
          "description": "Request timeout in milliseconds",
          "minimum": 1000
        },
        "retry_count": {
          "type": "integer",
          "description": "Number of retry attempts",
          "minimum": 0
        },
        "retry_backoff_ms": {
          "type": "integer",
          "description": "Backoff time between retries in milliseconds",
          "minimum": 100
        },
        "enable_auto_commit": {
          "type": "boolean",
          "description": "Enable automatic offset commit"
        },
        "auto_commit_interval_ms": {
          "type": "integer",
          "description": "Auto-commit interval in milliseconds",
          "minimum": 1000
        }
      },
      "additionalProperties": false
    },
    "market": {
      "type": "object",
      "description": "Trading and market data configuration",
      "required": ["rate_limit_per_second", "rate_limit_burst", "orderbook_depth", "max_order_size", "min_order_size", "max_position_size", "allowed_instruments", "fees"],
      "properties": {
        "rate_limit_per_second": {
          "type": "number",
          "description": "API rate limit (requests per second)",
          "minimum": 0
        },
        "rate_limit_burst": {
          "type": "integer",
          "description": "Rate limit burst capacity",
          "minimum": 1
        },
        "orderbook_depth": {
          "type": "integer",
          "description": "Number of price levels in orderbook",
          "minimum": 1
        },
        "max_order_size": {
          "type": "number",
          "description": "Maximum order size",
          "exclusiveMinimum": 0
        },
        "min_order_size": {
          "type": "number",
          "description": "Minimum order size",
          "exclusiveMinimum": 0
        },
        "max_position_size": {
          "type": "number",
          "description": "Maximum position size per account",
          "exclusiveMinimum": 0
        },
        "allowed_instruments": {
          "type": "array",
          "description": "List of allowed trading instruments (use ['*'] for all)",
          "items": {
            "type": "string"
          }
        },
        "fees": {
          "type": "object",
          "description": "Trading fee configuration",
          "required": ["maker", "taker", "withdrawal"],
          "properties": {
            "maker": {
              "type": "number",
              "description": "Maker fee rate (e.g., 0.001 = 0.1%)",
              "minimum": 0,
              "maximum": 1
            },
            "taker": {
              "type": "number",
              "description": "Taker fee rate (e.g., 0.002 = 0.2%)",
              "minimum": 0,
              "maximum": 1
            },
            "withdrawal": {
              "type": "number",
              "description": "Withdrawal fee rate",
              "minimum": 0,
              "maximum": 1
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "auth": {
      "type": "object",
      "description": "Authentication and authorization configuration",
      "required": ["jwt_secret", "jwt_expiry_minutes", "refresh_token_expiry_days", "session_timeout_minutes", "mfa_required", "max_login_attempts", "lockout_duration_minutes", "password_min_length", "password_require_special", "password_require_numbers", "password_require_uppercase"],
      "properties": {
        "jwt_secret": {
          "type": "string",
          "description": "JWT signing secret (must be set via environment variable or vault)"
        },
        "jwt_expiry_minutes": {
          "type": "integer",
          "description": "JWT token expiry time in minutes",
          "minimum": 1
        },
        "refresh_token_expiry_days": {
          "type": "integer",
          "description": "Refresh token expiry time in days",
          "minimum": 1
        },
        "session_timeout_minutes": {
          "type": "integer",
          "description": "Session timeout in minutes",
          "minimum": 1
        },
        "mfa_required": {
          "type": "boolean",
          "description": "Require multi-factor authentication"
        },
        "max_login_attempts": {
          "type": "integer",
          "description": "Maximum failed login attempts before lockout",
          "minimum": 1
        },
        "lockout_duration_minutes": {
          "type": "integer",
          "description": "Account lockout duration in minutes",
          "minimum": 1
        },
        "password_min_length": {
          "type": "integer",
          "description": "Minimum password length",
          "minimum": 6
        },
        "password_require_special": {
          "type": "boolean",
          "description": "Require special characters in passwords"
        },
        "password_require_numbers": {
          "type": "boolean",
          "description": "Require numbers in passwords"
        },
        "password_require_uppercase": {
          "type": "boolean",
          "description": "Require uppercase letters in passwords"
        }
      },
      "additionalProperties": false
    },
    "monitoring": {
      "type": "object",
      "description": "Observability and monitoring configuration",
      "required": ["metrics_enabled", "metrics_port", "tracing_enabled", "tracing_sample_rate", "tracing_endpoint", "health_check_enabled", "profiling_enabled"],
      "properties": {
        "metrics_enabled": {
          "type": "boolean",
          "description": "Enable Prometheus metrics endpoint"
        },
        "metrics_port": {
          "type": "integer",
          "description": "Port for metrics endpoint",
          "minimum": 1,
          "maximum": 65535
        },
        "tracing_enabled": {
          "type": "boolean",
          "description": "Enable distributed tracing"
        },
        "tracing_sample_rate": {
          "type": "number",
          "description": "Tracing sample rate (0.0 to 1.0)",
          "minimum": 0,
          "maximum": 1
        },
        "tracing_endpoint": {
          "type": "string",
          "description": "OpenTelemetry collector endpoint URL",
          "format": "uri"
        },
        "health_check_enabled": {
          "type": "boolean",
          "description": "Enable health check endpoint"
        },
        "profiling_enabled": {
          "type": "boolean",
          "description": "Enable CPU/memory profiling"
        }
      },
      "additionalProperties": false
    },
    "features": {
      "type": "object",
      "description": "Feature flags for optional functionality",
      "required": ["web_socket", "streaming", "ai_assistant", "social_trading", "margin_trading", "futures_trading", "options_trading", "dark_mode", "ab_testing"],
      "properties": {
        "web_socket": {
          "type": "boolean",
          "description": "Enable WebSocket connections for real-time data"
        },
        "streaming": {
          "type": "boolean",
          "description": "Enable market data streaming"
        },
        "ai_assistant": {
          "type": "boolean",
          "description": "Enable AI trading assistant"
        },
        "social_trading": {
          "type": "boolean",
          "description": "Enable social trading features"
        },
        "margin_trading": {
          "type": "boolean",
          "description": "Enable margin trading"
        },
        "futures_trading": {
          "type": "boolean",
          "description": "Enable futures trading"
        },
        "options_trading": {
          "type": "boolean",
          "description": "Enable options trading"
        },
        "dark_mode": {
          "type": "boolean",
          "description": "Enable dark mode UI theme"
        },
        "ab_testing": {
          "type": "boolean",
          "description": "Enable A/B testing framework"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
